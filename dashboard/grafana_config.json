{
  "apiVersion": 1,
  "providers": [
    {
      "name": "inference",
      "type": "file",
      "options": {
        "path": "/etc/grafana/provisioning/dashboards"
      }
    }
  ],
  "dashboard": {
    "title": "LLM Inference Server",
    "uid": "llm-inference",
    "timezone": "browser",
    "panels": [
      {
        "title": "Requests per Second",
        "type": "stat",
        "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "expr": "rate(requests_total[1m])",
            "legendFormat": "req/s"
          }
        ]
      },
      {
        "title": "Request Latency (p50 / p99)",
        "type": "timeseries",
        "gridPos": { "x": 6, "y": 0, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(request_latency_seconds_bucket[1m]))",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.99, rate(request_latency_seconds_bucket[1m]))",
            "legendFormat": "p99"
          }
        ]
      },
      {
        "title": "Tokens per Second",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(tokens_per_second_bucket[1m]))",
            "legendFormat": "tok/s (p50)"
          }
        ]
      },
      {
        "title": "Queue Depth",
        "type": "timeseries",
        "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "queue_depth",
            "legendFormat": "queued requests"
          }
        ]
      },
      {
        "title": "GPU Memory Used",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "gpu_memory_used_bytes{device='cuda:0'} / 1024^3",
            "legendFormat": "GPU 0 (GB)"
          },
          {
            "expr": "gpu_memory_used_bytes{device='cuda:1'} / 1024^3",
            "legendFormat": "GPU 1 (GB)"
          }
        ]
      },
      {
        "title": "Average Batch Size",
        "type": "stat",
        "gridPos": { "x": 12, "y": 12, "w": 6, "h": 4 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(batch_size_bucket[1m]))",
            "legendFormat": "avg batch size"
          }
        ]
      }
    ],
    "refresh": "10s",
    "schemaVersion": 39
  }
}
